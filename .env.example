# Django_star Project Configuration
# =================================

# Django Core
# Секретный ключ Django (сгенерируйте свой для production)
SECRET_KEY=your-secret-key-here
# Режим отладки: True для разработки, False для production
DEBUG=False
# Разрешенные хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# PostgreSQL Database Settings
# Использовать PostgreSQL (True) или SQLite (False)
USE_POSTGRES=True
# Название базы данных
DB_NAME=django_star_db
# Пользователь базы данных
DB_USER=postgres
# Пароль базы данных (измените на свой)
DB_PASSWORD=your_db_password
# Хост базы данных: localhost для разработки, db для Docker
DB_HOST=localhost
# Порт базы данных: 5432 для Docker, 5433 для локального PostgreSQL
DB_PORT=5432

# Application Version
APP_VERSION=1.0.0

# Logging (Loguru)
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOGURU_LEVEL=INFO
# При DEBUG=False автоматически включается JSON формат логов
# При DEBUG=True используется текстовый формат для читаемости